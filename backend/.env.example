# Copia este fichero a `.env` y rellena los valores. NUNCA subas `.env` al repo.
# El `.env` está en .gitignore precisamente para que no se filtre ninguna clave.

# Clave gratuita de football-data.org (https://www.football-data.org/client/register).
# Solo la usa el backend, dentro de /admin/recompute (1 vez al día). El frontend NUNCA la ve.
FOOTBALL_DATA_ORG_KEY=

# Token secreto que protege /admin/recompute para que nadie ajeno pueda forzar llamadas a la API.
# Inventa una cadena larga y aleatoria (p.ej. `openssl rand -hex 32`).
RECOMPUTE_TOKEN=

# Origen permitido para CORS: la URL de tu frontend (en Vercel) o localhost en desarrollo.
ALLOWED_ORIGIN=http://localhost:5173
